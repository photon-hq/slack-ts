{
  "name": "@photon-ai/slack",
  "version": "0.1.0",
  "description": "TypeScript SDK for Slack via Spectrum",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "proto"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "proto:update": "git submodule update --init --remote --merge proto",
    "proto:init": "git submodule update --init proto",
    "generate": "bun run proto:init && PATH=./node_modules/.bin:$PATH buf generate proto",
    "build": "bun run generate && tsdown",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "test": "bun test",
    "script:subscribe": "bun run scripts/subscribe.ts",
    "script:send": "bun run scripts/send.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.14.3",
    "nice-grpc": "^2.1.15",
    "nice-grpc-common": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@bufbuild/buf": "^1.68.1",
    "@types/bun": "latest",
    "ts-proto": "^2.11.6",
    "tsdown": "^0.22.0",
    "typescript": "^5.7.0",
    "ultracite": "7.5.8",
    "unrun": "^0.3.0"
  }
}
